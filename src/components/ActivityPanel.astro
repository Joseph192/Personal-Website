---
const { section } = Astro.props;
const normalizedTitle = section.title.toLowerCase().replace(/\s+/g, "-");
---

<article class="activity-panel">
  <h3>
    {normalizedTitle === "now" && (
      <svg class="activity-panel-icon" aria-hidden="true" viewBox="0 0 24 24">
        <path d="m15 12-8.5 8.5a2.1 2.1 0 0 1-3-3L12 9"></path>
        <path d="m17.6 2.4 4 4"></path>
        <path d="m14 6 4 4"></path>
        <path d="m12 2 10 10"></path>
      </svg>
    )}
    {normalizedTitle === "recently" && (
      <svg class="activity-panel-icon" aria-hidden="true" viewBox="0 0 24 24">
        <path d="M14.5 3.5c2.9-.9 5.2-.7 6 .1.8.8 1 3.1.1 6L13 17.2 6.8 11l7.7-7.5Z"></path>
        <circle cx="16.5" cy="7.5" r="1.5"></circle>
        <path d="m7 11-4 1.5 2.5 2.5"></path>
        <path d="m13 17-1.5 4-2.5-2.5"></path>
        <path d="m6.5 17.5-3 3"></path>
      </svg>
    )}
    {normalizedTitle === "good-reads" && (
      <svg class="activity-panel-icon" aria-hidden="true" viewBox="0 0 24 24">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
        <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15Z"></path>
      </svg>
    )}
    <span>{section.title}</span>
  </h3>
  <ul>
    {section.items.map((item) => <li set:html={item} />)}
  </ul>
</article>
